{
  "name": "replate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "compile": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat compile",
    "deploy": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/deploy.ts",
    "test:contracts": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat test",
    "verify": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat verify",
    "export-abi": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/export-abi.ts"
  },
  "dependencies": {
    "@farcaster/miniapp-wagmi-connector": "latest",
    "@tanstack/react-query": "latest",
    "@wagmi/core": "latest",
    "@farcaster/miniapp-sdk": "^0.2.3",
    "@google-cloud/vision": "^5.3.4",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "node-cron": "^3.0.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "viem": "latest",
    "wagmi": "latest"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.6.0",
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "hardhat": "^2.22.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}