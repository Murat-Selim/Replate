{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": [
    "api/**/*.ts",
    "server/**/*.ts",
    "src/lib/**/*.ts",
    "hardhat.config.cts",
    "hardhat.config.d.ts",
    "scripts/**/*.cts"
  ],
  "exclude": ["node_modules"]
}
